# OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=gpt-4o-mini

# HTTP API (scripts/serve.py): require this header on mutating routes when set
# API_KEY=
# HOST=0.0.0.0
# PORT=8000

# Corpus directory for uploads + manual drops (default: data/raw)
# DOCUMENTS_RAW_DIR=/data/corpus

# Optional SQL live sync (merged at reindex time)
# SQL_DATABASE_URL=sqlite:///./data/app.db
# SQL_SYNC_QUERY=SELECT * FROM documents
# SQL_ID_COLUMN=id
# SQL_UPDATED_AT_COLUMN=updated_at
# SQL_SOURCE_NAME=app_db
# SQL_TEXT_COLUMNS=title,body

# Production: mount indexes elsewhere (Kubernetes PVC, EFS, etc.)
# CHROMA_PERSIST_DIR=/data/vector_store/chroma
# BM25_INDEX_DIR=/data/vector_store/bm25

# Hugging Face cache (speed up cold starts; bake in CI or use a volume)
# HF_HOME=/opt/hf

# Optional tuning (defaults are in code): bm25_k, vector_k, fusion_top_n, rerank_top_n
# are passed to run_pipeline() / hybrid_retrieve() — override in code or wrap ask.py.

# Phase 4 — observability / LLMOps
# BUILD_ID=ci-12345
# GIT_SHA=abc123
# SERVICE_VERSION=0.2.0
# LOG_JSON=1
# LOG_LEVEL=INFO
# METRICS_REQUIRE_AUTH=0

# Optional LangSmith tracing (LangChain/LangGraph execution traces)
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=enterprise-rag-local
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Optional Langfuse self-hosted tracing (fully local, no cloud required)
# 1. Start the stack:  docker compose -f docker-compose.langfuse.yml up -d
# 2. Open http://localhost:3000 → create account → Settings → API keys
# 3. Copy pk-lf-... and sk-lf-... below
# LANGFUSE_TRACING=true
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=http://localhost:3000
