# OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=gpt-4o-mini

# HTTP API: require this header on mutating routes when set
# API_KEY=
# HOST=0.0.0.0
# PORT=8000

# Corpus + indexes (Project B)
# DOCUMENTS_RAW_DIR=/data/corpus
# CHROMA_PERSIST_DIR=/data/vector_store/chroma
# BM25_INDEX_DIR=/data/vector_store/bm25

# Intent model (Project D-style paths)
# MODELS_DIR=/app/models
# INTENT_REGISTRY_PATH=/app/models/intent_registry.json
# INTENT_TRAIN_CSV=/app/data/raw/intent_train.csv

# Feedback (Project E)
# FEEDBACK_DB=/app/data/feedback.db

# Readiness: require trained intent artifact
# INTENT_REQUIRED_FOR_READY=0

# Hugging Face cache
# HF_HOME=/opt/hf

# Observability
# BUILD_ID=ci-12345
# GIT_SHA=abc123
# SERVICE_VERSION=1.0.0
# LOG_JSON=1
# LOG_LEVEL=INFO
# METRICS_REQUIRE_AUTH=0
