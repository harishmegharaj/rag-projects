# HTTP
HOST=0.0.0.0
PORT=8000
# Optional: require X-API-Key or Authorization: Bearer … on mutating routes
API_KEY=

# OpenAI — used when TRANSCRIPTION_BACKEND=openai (or auto + key set)
OPENAI_API_KEY=

# Sales transcript reasoning with LLM (optional)
# Used by /v1/nlp/sales-insights and /v1/videos/{video_id}/sales-insights when use_llm=true
SALES_REASONING_MODEL=gpt-4.1-mini
SALES_REASONING_TEMPERATURE=0.2

# Transcription backend: auto | openai | local | deepgram
#   auto — OpenAI if OPENAI_API_KEY is set, else local faster-whisper
#   local — faster-whisper (install: pip install -r requirements-local.txt)
#   deepgram — cloud STT with speaker diarization + timestamps per turn (needs DEEPGRAM_API_KEY)
TRANSCRIPTION_BACKEND=auto

# Deepgram — used when TRANSCRIPTION_BACKEND=deepgram
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2

# Local ASR (faster-whisper) — only when backend resolves to local
LOCAL_WHISPER_MODEL=base
LOCAL_WHISPER_DEVICE=cpu
LOCAL_WHISPER_COMPUTE_TYPE=int8

# Paths (optional overrides)
# PROJECT_ROOT is inferred from package location
VIDEO_STORAGE_DIR=
DATABASE_URL=sqlite:///./data/app.sqlite3

# Transcription (OpenAI)
WHISPER_MODEL=whisper-1
# Chunk long audio: OpenAI when file is large; local when duration or size exceeds threshold
TRANSCRIBE_SEGMENT_SECONDS=480
# Max upload size in bytes (default 500 MiB)
MAX_UPLOAD_BYTES=524288000
