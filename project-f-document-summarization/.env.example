HOST=0.0.0.0
PORT=8020

# Optional: require X-API-Key or Authorization: Bearer <key>
# API_KEY=

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

DATA_DIR=data
JOBS_DB=data/jobs.db

# HMAC secret for outbound webhook signatures (X-Signature: sha256=...)
WEBHOOK_SECRET=change-me-in-production

# Map-reduce chunking (characters)
CHUNK_SIZE=3500
CHUNK_OVERLAP=400
STUFF_MAX_CHARS=12000
