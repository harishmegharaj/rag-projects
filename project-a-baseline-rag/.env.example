# Copy to .env and fill in as needed

# --- LLM (optional; without it, rag.py uses a stub) ---
# OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Vector store: local Chroma (default) ---
# VECTOR_BACKEND=chroma
CHROMA_PERSIST_DIR=./vector_store/chroma

# --- Vector store: Pinecone (production-style) ---
# VECTOR_BACKEND=pinecone
# PINECONE_API_KEY=
# PINECONE_INDEX_NAME=baseline-rag
# Optional: isolate tenants / envs
# PINECONE_NAMESPACE=
# For scripts/create_pinecone_index.py (serverless only)
# PINECONE_CLOUD=aws
# PINECONE_REGION=us-east-1
